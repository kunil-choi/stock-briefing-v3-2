# .env.example
# 아래 키들을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨)

# Claude (Anthropic) API 키
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 키
# https://console.cloud.google.com/ → YouTube Data API v3 활성화
YOUTUBE_API_KEY=your_youtube_api_key_here

# GitHub Personal Access Token (contents:write 권한 필요)
# https://github.com/settings/tokens
GH_TOKEN=your_github_token_here

# 관리자 페이지 비밀번호 (기본값: stock2026!)
ADMIN_PASSWORD=stock2026!
